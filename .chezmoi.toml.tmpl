{{- $os := "linux" -}}
{{- if eq .chezmoi.os "windows" }}
{{- $os = "windows" -}}
{{- end }}

{{- $key_recipient := "4009CCB16D81F799" -}}

{{- $choices := list "h0" "w1" "w2" -}}
{{- $avatar := promptChoice "Choose your avatar" $choices -}}

sourceDir = {{ joinPath .chezmoi.sourceDir $os }}
encryption = "gpg"
[gpg]
  recipient = "{{ $key_recipient }}"

[data]
    os = {{ $os | quote }}
    avatar = {{ $avatar | quote }}
    [date.user]
        name = "{{ pass (print $avatar "/git_name") }}"
        email = "{{ pass (print $avatar "/git_email") }}"
        gpg_id = "{{ pass (print $avatar "/git_gpg_id") }}"
